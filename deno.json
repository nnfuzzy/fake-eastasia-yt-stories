{
  "tasks": {
    "story": "deno run -A cli.ts",
    "tts": "deno run -A tts.ts",
    "test": "deno test -A tests/",
    "test:watch": "deno test -A --watch tests/",
    "fmt": "deno fmt",
    "lint": "deno lint",
    "check": "deno fmt --check && deno lint && deno check cli.ts tts.ts"
  },
  "imports": {
    "genkit": "npm:genkit@^1.0.0",
    "@genkit-ai/google-genai": "npm:@genkit-ai/google-genai@^1.0.0",
    "@std/cli": "jsr:@std/cli@^1.0.0",
    "@std/yaml": "jsr:@std/yaml@^1.0.0",
    "@std/path": "jsr:@std/path@^1.0.0",
    "@std/fs": "jsr:@std/fs@^1.0.0",
    "@std/dotenv": "jsr:@std/dotenv@^0.225.3",
    "@std/assert": "jsr:@std/assert@^1.0.0",
    "wav": "npm:wav@^1.0.2",
    "zod": "npm:zod@^3.24.0"
  },
  "compilerOptions": {
    "lib": ["deno.ns", "dom"]
  },
  "fmt": {
    "lineWidth": 100,
    "indentWidth": 2,
    "singleQuote": true
  },
  "nodeModulesDir": "auto"
}
